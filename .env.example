# NepalToolkit — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local for local development.
# Add all variables to Vercel dashboard → Settings → Environment Variables.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────
# Get these from: supabase.com → Project → Settings → API

# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Server-only — NEVER prefix with NEXT_PUBLIC_
# Used by cron jobs and API routes that INSERT/UPDATE data
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# ── Gold / Silver API ─────────────────────────────────────────
# Source: rapidapi.com/search "Nepali Gold Silver Rate Live"
# Free tier: 500 requests/month (well within 1 req/day)
RAPIDAPI_KEY=your_rapidapi_key_here


# ── Cron Security ─────────────────────────────────────────────
# A random secret that protects the /api/cron/fetch-rates endpoint.
# Generate with: openssl rand -hex 32
# Vercel automatically sends this as Authorization: Bearer <secret>
# when configured under Vercel Cron.
CRON_SECRET=replace_with_openssl_rand_hex_32_output


# ── Optional: Upstash Redis (response caching) ───────────────
# Adds an in-memory cache layer in front of Supabase.
# Free tier: 10,000 commands/day — more than enough.
# Get from: upstash.com → Redis → Create Database → REST API
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here


# ── Optional: Google Analytics 4 ─────────────────────────────
# For traffic analytics and SEO monitoring.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX


# ── Site Metadata ─────────────────────────────────────────────
# Used by next-sitemap and OG meta generation
NEXT_PUBLIC_SITE_URL=https://www.nepaltoolkit.com
